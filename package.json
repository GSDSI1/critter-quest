{
  "name": "critter-quest",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/ensure-dev-port.mjs && vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "gen-assets": "node scripts/generate-png-assets.mjs",
    "pack-tileset": "node scripts/pack-tileset.mjs",
    "import-tileset": "node scripts/import-kenney-tileset.mjs",
    "pack-critters": "node scripts/pack-critter-atlas.mjs",
    "lint": "eslint .",
    "verify": "node scripts/verify-build.mjs",
    "check": "npm run verify && npm run build",
    "smoke": "node scripts/smoke-http.mjs",
    "play": "node -e \"console.log('\\n  Critter Quest → http://127.0.0.1:5180\\n')\" && npm run dev",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "node scripts/ensure-dev-port.mjs && playwright test",
    "test:all": "npm run verify && npx tsc --noEmit && npm run test:unit && npm run build && npm run test:e2e"
  },
  "dependencies": {
    "phaser": "^3.88.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "happy-dom": "^20.10.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.61.0",
    "vite": "^6.0.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8"
  }
}
